# Copy to .env.local and adjust per environment. All values are PUBLIC (inlined
# into the app bundle) — never put secrets here.

# Base URL of the HR REST API
EXPO_PUBLIC_API_URL=https://hr-api.uzgidro.uz

# OnlyOffice document server (serves the editor api.js)
EXPO_PUBLIC_ONLYOFFICE_URL=https://doc-editor.uzgidro.uz
